# ---------------------------------------------------------------------------
# Shoprite MCP Server – Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# ---------------------------------------------------------------------------

# -- Shoprite scraper settings -----------------------------------------------
SHOPRITE_BASE_URL=https://www.shoprite.com
REQUEST_TIMEOUT=30
MAX_PRODUCTS=50

# -- Network ports ------------------------------------------------------------
MCP_PORT=8080        # Port exposed by the mcp-server container
PROXY_PORT=9090      # Port exposed by the mcp-proxy container

# -- Redis --------------------------------------------------------------------
REDIS_PASSWORD=changeme_strong_password_here

# -- Docker image registry ----------------------------------------------------
DOCKER_REGISTRY=ghcr.io/mjpinot
IMAGE_TAG=latest

# -- TLS (production only) ----------------------------------------------------
# DOMAIN=mcp.yourdomain.com
# LETSENCRYPT_EMAIL=you@example.com
